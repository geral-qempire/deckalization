# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.python-version.local

# ---- uv ----
# Keep uv.lock committed; ignore caches only

# ---- Env / secrets ----
.env
.env.*
!.env.local.example

# ---- Node / Convex ----
node_modules/
.convex/
# convex/_generated is committed so generated types/clients are available in CI

# ---- Models / data caches ----
.cache/
models/
data/
*.bulk.json
# The frontend bundles static data modules under src/data — not an ML cache.
!app/deckalization-front-end/src/data/
!app/deckalization-front-end/src/data/**

# ---- OS / editor ----
.DS_Store
*.swp
.idea/
.vscode/

# ---- LangGraph ----
.langgraph_api/

# ---- Eval artifacts (regenerable from LangSmith; not a source of truth) ----
agents/evals/datasets/experiment_snapshot.json
