# ============================================================
# deckalization — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. NEVER commit real secrets.
# ============================================================

# ---- LLM gateway (OpenRouter, OpenAI-compatible) ----
OPENROUTER_API_KEY=
# Base URL is fixed for OpenRouter; override only if self-hosting a gateway.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- LangSmith (observability + evals) ----
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=deckalization
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- Convex (data layer) ----
# Populated by `npx convex dev` (writes to .env.local too); mirror here for Python.
CONVEX_URL=
# Deploy key for non-interactive / CI deploys (optional in local dev).
CONVEX_DEPLOY_KEY=
