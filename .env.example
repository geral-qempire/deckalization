# ============================================================
# deckalization — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored. NEVER commit real secrets.
# ============================================================

# ------------------------------------------------------------
# Environments (dev / prod) — convention
#   dev  : your machine + PR/CI. Use the *-dev OpenRouter key and the
#          deckalization-dev LangSmith project. Convex dev deployment.
#   prod : LangGraph Platform deployment. Use the *-prod OpenRouter key and
#          the deckalization-prod LangSmith project. Convex prod deployment.
# Same VARIABLE NAMES in every environment; only the VALUES differ. This file
# documents the dev defaults; prod values are set as deployment/CI secrets.
# ------------------------------------------------------------

# ---- LLM gateway (OpenRouter, OpenAI-compatible) ----
# Dev: use your "deckalization-dev" OpenRouter key here.
# Prod: set the "deckalization-prod" key as a LangGraph Platform secret (Phase 7).
OPENROUTER_API_KEY=
# Base URL is fixed for OpenRouter; override only if self-hosting a gateway.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- LangSmith (observability + evals) ----
# Same API key across environments; separate dev/prod by PROJECT name.
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=deckalization-dev   # prod sets this to deckalization-prod
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---- Convex (data layer) ----
# Nothing to set here. The Convex CLI manages these vars automatically:
#   dev  : `npx convex dev` writes CONVEX_URL + CONVEX_DEPLOYMENT to `.env.local`.
#   prod : CONVEX_URL + CONVEX_DEPLOY_KEY are set as CI / deployment secrets (Phases 6–7).
# agents/config.py reads `.env.local` automatically, so dev needs no manual step.
